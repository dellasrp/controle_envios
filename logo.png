<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Controle de Envios · Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Host+Grotesk:ital,wght@0,300..800;1,300..800&display=swap" rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
  <script>
    tailwind.config = {
      theme: { extend: { colors: { ink: '#093E34', slab: '#305D54', accent: '#16836D', accentBright: '#1BA085', lime: '#8DC540' }, fontFamily: { sans: ['Host Grotesk', 'ui-sans-serif', 'system-ui', 'Segoe UI', 'Roboto', 'Helvetica', 'Arial', 'sans-serif'] } } }
    };
  </script>
</head>
<body class="min-h-screen bg-slate-100 font-sans text-slate-800">
  <header class="border-b border-slate-200 bg-ink text-slate-100">
    <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3">
      <div class="flex items-center gap-3">
        <img src="/img/logo-white.png" alt="smar(apd)" class="h-6 w-auto" />
        <span class="font-semibold tracking-tight">Controle de Envios</span>
      </div>
      <nav class="flex items-center gap-1 text-sm">
        <a href="/app.html" class="rounded px-3 py-1.5 text-slate-300 hover:bg-white/10">Tabela</a>
        <a href="/dashboard.html" class="rounded px-3 py-1.5 font-medium text-white bg-white/10">Dashboard</a>
        <a id="linkPrazos" href="/prazos.html" class="hidden rounded px-3 py-1.5 text-slate-300 hover:bg-white/10">Parametrização</a>
        <a id="linkUsuarios" href="/usuarios.html" class="hidden rounded px-3 py-1.5 text-slate-300 hover:bg-white/10">Usuários</a>
        <div class="mx-2 h-5 w-px bg-white/20"></div>
        <div id="userNome" class="text-sm font-medium"></div>
        <button onclick="logout()" class="ml-2 rounded px-3 py-1.5 text-slate-300 hover:bg-white/10">Sair</button>
      </nav>
    </div>
  </header>

  <main class="mx-auto max-w-7xl px-4 py-6">
    <div class="mb-4 flex flex-wrap items-end justify-between gap-3">
      <h1 class="text-xl font-semibold tracking-tight">Painel gerencial</h1>
      <div class="flex items-center gap-2">
        <select id="anoSelect" class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm outline-none focus:border-accent"></select>
        <select id="periodoSelect" class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm outline-none focus:border-accent"></select>
      </div>
    </div>
    <p id="prazoInfo" class="mb-4 text-sm text-slate-500"></p>

    <div class="mb-6 grid grid-cols-2 gap-4 lg:grid-cols-4">
      <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <div class="text-xs uppercase tracking-wide text-slate-500">Total de clientes</div>
        <div id="kpiTotal" class="mt-1 text-3xl font-semibold">—</div>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <div class="text-xs uppercase tracking-wide text-slate-500">Concluídos no período</div>
        <div id="kpiConcluidos" class="mt-1 text-3xl font-semibold text-emerald-600">—</div>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <div class="text-xs uppercase tracking-wide text-slate-500">Pendentes no período</div>
        <div id="kpiPendentes" class="mt-1 text-3xl font-semibold text-amber-600">—</div>
      </div>
      <div class="rounded-xl border border-red-200 bg-red-50 p-4 shadow-sm">
        <div class="text-xs uppercase tracking-wide text-red-500">Em atraso</div>
        <div id="kpiAtrasados" class="mt-1 text-3xl font-semibold text-red-600">—</div>
      </div>
    </div>

    <div class="mb-6 grid grid-cols-2 gap-4 lg:grid-cols-4">
      <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <div class="text-xs uppercase tracking-wide text-slate-500">Integração AM x CP</div>
        <div id="kpiIntegracao" class="mt-1 text-2xl font-semibold">—</div>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <div class="text-xs uppercase tracking-wide text-slate-500">Com gerador</div>
        <div id="kpiGerador" class="mt-1 text-2xl font-semibold">—</div>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <div class="text-xs uppercase tracking-wide text-slate-500">Concluídos no prazo</div>
        <div id="kpiNoPrazo" class="mt-1 text-2xl font-semibold text-emerald-600">—</div>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <div class="text-xs uppercase tracking-wide text-slate-500">Concluídos em atraso</div>
        <div id="kpiConcluidoAtraso" class="mt-1 text-2xl font-semibold text-red-500">—</div>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-4 lg:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm lg:col-span-2">
        <h2 class="mb-3 text-sm font-semibold text-slate-700">Concluído x Pendente por período</h2>
        <canvas id="chartPeriodo" height="120"></canvas>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <h2 class="mb-3 text-sm font-semibold text-slate-700">Distribuição por órgão</h2>
        <canvas id="chartOrg" height="220"></canvas>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm lg:col-span-2">
        <h2 class="mb-3 text-sm font-semibold text-slate-700">Clientes por técnico (no período)</h2>
        <canvas id="chartTecnico" height="180"></canvas>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <h2 class="mb-3 text-sm font-semibold text-slate-700">Evolução de conclusão (%)</h2>
        <canvas id="chartEvolucao" height="180"></canvas>
      </div>
    </div>

    <div class="mt-4 rounded-xl border border-slate-200 bg-white shadow-sm">
      <button onclick="alternarPendentes()" class="flex w-full items-center justify-between px-4 py-3 text-left">
        <span class="text-sm font-semibold text-slate-700">Clientes pendentes no período (<span id="qtdPendentes">0</span>)</span>
        <span id="setaPendentes" class="text-slate-400">▼</span>
      </button>
      <div id="painelPendentes" class="hidden border-t border-slate-200">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-slate-100 bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
              <th class="px-4 py-2">Cliente</th>
              <th class="px-4 py-2">Órgão</th>
              <th class="px-4 py-2">Técnico</th>
              <th class="px-4 py-2">Situação</th>
              <th class="px-4 py-2">Observação</th>
            </tr>
          </thead>
          <tbody id="pendentesBody"></tbody>
        </table>
      </div>
    </div>
  </main>

  <script src="/js/auth.js"></script>
  <script src="/js/api.js"></script>
  <script src="/js/dashboard.js"></script>
</body>
</html>
